{
  "expo": {
    "name": "VASP Systemic",
    "slug": "vasp-systemic-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "vasp-systemic-mobile",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#020617"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.vaspsystemic.mobile"
    },
    "android": {
      "backgroundColor": "#020617",
      "package": "com.vaspsystemic.mobile"
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": ["expo-router", "expo-font", "expo-web-browser"],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
